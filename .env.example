# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your local .env file or in your deployment platform's secrets manager.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

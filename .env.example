# EvalBench environment configuration
#
# Copy this file to .env and fill in the values you want active. Anything
# left as a placeholder will be treated as unset by the server, so the
# real-model run endpoint will reject real runs against that provider.
#
# NEVER commit a .env file with real keys. .env is git-ignored.

# ---------------------------------------------------------------
# Real-model provider API keys (server-side only)
# ---------------------------------------------------------------

# GEMINI_API_KEY: Required for real Gemini evaluations.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------------------------------------------
# Default model selection (used when a real run does not specify a
# model explicitly). Defaults are the free-tier-friendly choices.
# ---------------------------------------------------------------

# DEFAULT_MODEL_PROVIDER: "gemini" | "groq" | "openrouter"
DEFAULT_MODEL_PROVIDER=gemini

# DEFAULT_MODEL_NAME: model id within the chosen provider
DEFAULT_MODEL_NAME=gemini-2.5-flash

# ---------------------------------------------------------------
# Database — Neon Postgres (production) / local Postgres (dev)
# ---------------------------------------------------------------
#
# Production (Neon):
#   DATABASE_URL = pooled connection string
#     postgresql://user:pass@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1
#   DIRECT_URL = direct connection string (for migrations)
#     postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb
#
# Local dev:
#   DATABASE_URL = postgresql://<user>@localhost:5432/<dbname>
#   DIRECT_URL   = same as DATABASE_URL
DATABASE_URL=
DIRECT_URL=

# ---------------------------------------------------------------
# App metadata (optional)
# ---------------------------------------------------------------

# APP_URL: The public URL where this app is hosted.
APP_URL="https://ai-evaluation-dashboard.vercel.app"
